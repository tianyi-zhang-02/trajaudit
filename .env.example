# Copy this file to `.env` and fill in your own values.
# `.env` is git-ignored. Never commit real keys.

# Anthropic Claude API — used by layer3_semantic.providers.anthropic_provider
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI API — used by layer3_semantic.providers.openai_provider
OPENAI_API_KEY=your-openai-key-here

# Local vLLM-served judge — base URL of an OpenAI-compatible server
# Used by layer3_semantic.providers.vllm_provider
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct
